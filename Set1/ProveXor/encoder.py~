def repeating_key_xor(byte_to_encode,key):
    i=0
    j=0
    xor=bytearray(len(byte_to_encode))
    for b in byte_to_encode:
        xor[j]=b^key[i]
        j=j+1
        i=i+1
        if i>=len(key):
            i=i%len(key)
    return xor

with open('canzone.txt',"r") as f:
    data_to_encode=f.read()
    f.close()
key="Marracash : Dubbi"


string_byte=bytes(data_to_encode,encoding='utf-8')

key_byte=bytes(key,encoding='utf-8')

xor=repeating_key_xor(string_byte,key_byte)

print(type(xor))
print(xor.hex())
with open('canzone_encripted.txt','w') as f:
    f.write(xor.hex())
    f.close()
